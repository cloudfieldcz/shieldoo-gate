# Source this (or export) before `go get` / `go build`.
# Point GOPROXY at the gate; embed PROJECT:TOKEN when proxy auth is enabled
# (use `default` as the project if you don't care about segmentation).
export GOPROXY="http://default:test-token-123@localhost:8087"

# Mark the private module path so the go client does NOT leak it to / verify it
# against the public checksum database (sum.golang.org).
export GOPRIVATE="github.com/mycompany/*"
export GONOSUMCHECK=1
