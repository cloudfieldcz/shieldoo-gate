<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="shieldoo-gate" value="http://localhost:5001/v3/index.json" />
  </packageSources>
  <packageSourceCredentials>
    <shieldoo-gate>
      <!-- Basic auth: Username = project label; ClearTextPassword = token. -->
      <add key="Username" value="dotnet-demo" />
      <add key="ClearTextPassword" value="test-token-123" />
    </shieldoo-gate>
  </packageSourceCredentials>
</configuration>
