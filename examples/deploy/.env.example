# Shieldoo Gate — Example deployment environment variables
# Copy to .env and fill in real values. Never commit .env itself.

# ---------- Image version ----------
SGW_VERSION=latest

# ---------- Domain ----------
# Replace with your actual domain
SGW_DOMAIN=shieldoo-gate.example.com
ACME_EMAIL=admin@example.com

# ---------- PostgreSQL ----------
POSTGRES_USER=shieldoo
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password
POSTGRES_DB=shieldoo

# ---------- AI Scanner (optional, opt-in) ----------
# AI_SCANNER_ENABLED=true
# AI_SCANNER_API_KEY=your-azure-openai-api-key
# AI_SCANNER_PROVIDER=azure_openai
# AI_SCANNER_MODEL=gpt-5.4-mini
# AI_SCANNER_AZURE_ENDPOINT=https://your-instance.openai.azure.com/
# AI_SCANNER_AZURE_DEPLOYMENT=gpt-54-mini
