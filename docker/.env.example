# Shieldoo Gate — Docker environment variables
# Copy to .env and fill in real values. Never commit .env itself.

# OIDC authentication (admin API)
SGW_AUTH_ISSUER_URL=
SGW_AUTH_CLIENT_ID=
SGW_OIDC_CLIENT_SECRET=

# Proxy authentication — shared token for pip/npm/docker/nuget/gem/go clients
SGW_PROXY_TOKEN=

# AI Scanner (Azure OpenAI) — opt-in, requires valid API key
AI_SCANNER_ENABLED=false
AI_SCANNER_API_KEY=
AI_SCANNER_PROVIDER=azure_openai
AI_SCANNER_AZURE_ENDPOINT=
AI_SCANNER_AZURE_DEPLOYMENT=gpt-54-mini
# AI_SCANNER_MODEL — only needed when provider is "openai" (not Azure)

# PostgreSQL DSN (only if database.backend is set to "postgres" in config.yaml)
# SGW_DATABASE_POSTGRES_DSN=postgres://user:pass@host:5432/shieldoo?sslmode=require
