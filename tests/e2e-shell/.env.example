# Shieldoo Gate — E2E test environment variables
# Copy to .env and fill in real values. Never commit .env itself.

# AI Scanner (Azure OpenAI) — set to enable AI scanner e2e tests
SGW_SCANNERS_AI_ENABLED=false
AI_SCANNER_ENABLED=false
AI_SCANNER_API_KEY=
AI_SCANNER_PROVIDER=azure_openai
AI_SCANNER_AZURE_ENDPOINT=
AI_SCANNER_AZURE_DEPLOYMENT=gpt-54-mini

# Proxy authentication (optional)
# SGW_PROXY_AUTH_ENABLED=true
# SGW_PROXY_TOKEN=your-shared-token
