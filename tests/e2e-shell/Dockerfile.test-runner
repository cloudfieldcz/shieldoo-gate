# Dockerfile.test-runner — Containerized E2E test client for Shieldoo Gate
#
# Contains ALL package managers needed to test every proxy adapter.
# All tool versions MUST be pinned (per CLAUDE.md).
#
# Build context: repository root (../../)
# Usage: docker compose -f tests/e2e-shell/docker-compose.e2e.yml up test-runner

# --- shdg CLI build stage (added by test_vuln_scan_shdg) ---
# We do NOT need the rest of internal/ — the shdg main package is Go-stdlib-only.
# We also do NOT git-stamp the binary (no .git in the build context); a hard-coded
# "e2e" value is sufficient for the smoke test.
FROM golang:1.26.5-alpine@sha256:0178a641fbb4858c5f1b48e34bdaabe0350a330a1b1149aabd498d0699ff5fb2 AS shdg-build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY cmd/shdg ./cmd/shdg
RUN CGO_ENABLED=0 go build \
        -ldflags "-X main.Version=e2e -X main.Commit=e2e" \
        -o /out/shdg ./cmd/shdg

FROM ubuntu:26.04@sha256:53958ec7b67c2c9355df922dd08dbf0360611f8c3cdb656875e81873db9ffdba

# Avoid interactive prompts during package install
ENV DEBIAN_FRONTEND=noninteractive

# ---------------------------------------------------------------------------
# Base utilities
# ---------------------------------------------------------------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates=20260601~26.04.1 \
        curl=8.18.0-1ubuntu2.* \
        file=1:5.46-5build2 \
        jq=1.8.1-* \
        postgresql-client \
        unzip=6.0-29ubuntu* \
        git=1:2.53.0-1ubuntu* \
    && rm -rf /var/lib/apt/lists/*

# ---------------------------------------------------------------------------
# Python — uv (pinned)
# ---------------------------------------------------------------------------
ARG UV_VERSION=0.6.0
RUN curl -LsSf "https://github.com/astral-sh/uv/releases/download/${UV_VERSION}/uv-installer.sh" | \
    sh -s
ENV PATH="/root/.local/bin:${PATH}"

# Install Python via uv (pinned version)
ARG PYTHON_VERSION=3.12.8
RUN uv python install "${PYTHON_VERSION}"

# ---------------------------------------------------------------------------
# Node.js (pinned via NodeSource)
# ---------------------------------------------------------------------------
ARG NODE_MAJOR=20
RUN curl -fsSL "https://deb.nodesource.com/setup_${NODE_MAJOR}.x" | bash - && \
    apt-get install -y --no-install-recommends nodejs=20.19.0-1nodesource1 && \
    rm -rf /var/lib/apt/lists/*

# ---------------------------------------------------------------------------
# .NET SDK (pinned) — Ubuntu 26.04 ships .NET natively in universe, so we no
# longer add the packages.microsoft.com feed (which doesn't carry 8.0 for 26.04
# anyway). The NuGet e2e only `dotnet restore`s a net8.0 fixture, which is
# framework-agnostic and resolves fine under the 10.0 SDK.
# ---------------------------------------------------------------------------
ARG DOTNET_VERSION=10.0
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        "dotnet-sdk-${DOTNET_VERSION}=10.0.109-0ubuntu1~26.04.*" \
    && rm -rf /var/lib/apt/lists/*

# Disable .NET telemetry in test environment
ENV DOTNET_CLI_TELEMETRY_OPTOUT=1
ENV DOTNET_NOLOGO=1

# ---------------------------------------------------------------------------
# Java + Maven (pinned)
# ---------------------------------------------------------------------------
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        openjdk-21-jdk-headless=21.0.* \
        maven=3.9.12-* \
    && rm -rf /var/lib/apt/lists/*

# ---------------------------------------------------------------------------
# Ruby + Bundler (pinned)
# ---------------------------------------------------------------------------
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        ruby=1:3.3build1 \
        ruby-dev=1:3.3build1 \
    && gem install bundler -v 2.5.6 --no-document \
    && rm -rf /var/lib/apt/lists/*

# ---------------------------------------------------------------------------
# Go (pinned with checksum)
# ---------------------------------------------------------------------------
ARG GO_VERSION=1.26.4
ARG GO_SHA256=1153d3d50e0ac764b447adfe05c2bcf08e889d42a02e0fe0259bd47f6733ad7f
RUN curl -fsSL "https://go.dev/dl/go${GO_VERSION}.linux-amd64.tar.gz" -o /tmp/go.tar.gz && \
    echo "${GO_SHA256}  /tmp/go.tar.gz" | sha256sum -c - && \
    tar -C /usr/local -xzf /tmp/go.tar.gz && \
    rm /tmp/go.tar.gz
ENV PATH="/usr/local/go/bin:${PATH}"

# ---------------------------------------------------------------------------
# crane — OCI image tool for Docker E2E tests (pinned)
# ---------------------------------------------------------------------------
ARG CRANE_VERSION=0.19.1
RUN curl -fsSL "https://github.com/google/go-containerregistry/releases/download/v${CRANE_VERSION}/go-containerregistry_Linux_x86_64.tar.gz" \
    -o /tmp/crane.tar.gz && \
    tar -C /usr/local/bin -xzf /tmp/crane.tar.gz crane && \
    chmod +x /usr/local/bin/crane && \
    rm /tmp/crane.tar.gz

# ---------------------------------------------------------------------------
# shdg CLI — built in the shdg-build stage above
# ---------------------------------------------------------------------------
COPY --from=shdg-build /out/shdg /usr/local/bin/shdg
RUN chmod +x /usr/local/bin/shdg

# ---------------------------------------------------------------------------
# Copy test scripts
# ---------------------------------------------------------------------------
WORKDIR /tests
COPY tests/e2e-shell/ /tests/
RUN chmod +x /tests/*.sh

ENTRYPOINT ["/bin/bash"]
CMD ["./run_all.sh"]
